{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schemas/master/src/tauri.conf.json",
  "productName": "Paperclip",
  "version": "0.1.0",
  "identifier": "ai.paperclip.desktop",
  "build": {
    "frontendDist": "../../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "title": "Paperclip",
    "windows": [
      {
        "title": "Paperclip",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
